/* pages\detail\detail.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #e8f5e9, #ffffff);
  padding: 30rpx;
}

/* 顶部卡片 */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
  text-align: center;
}

.img {
  width: 100%;
  height: 380rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  margin-top: 10rpx;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

/* 信息模块 */
.section {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

/* 标题 */
.title {
  font-size: 28rpx;
  font-weight: bold;
  color: #4caf50;
  margin-bottom: 10rpx;
}

/* 内容 */
.content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}