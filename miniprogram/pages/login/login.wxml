<!--pages/login/login.wxml-->
<view class="container">

<view class="title">用户登录</view>

<input 
  class="input"
  placeholder="请输入用户名"
  bindinput="onUsernameInput"
/>

<input 
  class="input"
  placeholder="请输入密码"
  password="true"
  bindinput="onPasswordInput"
/>

<button class="btn" bindtap="handleLogin">
  登录
</button>

<view class="link" bindtap="goRegister">
  没有账号？去注册
</view>

</view>